# General
NODE_ENV=development

# API
API_PORT=3000
# Better Auth signs sessions with this. Use a long random string in any
# non-local environment (e.g. `openssl rand -base64 32`).
BETTER_AUTH_SECRET=change_me_for_local_dev
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

# Email — Better Auth uses these for password reset + verification.
# In dev, point at Mailpit (mailbox UI at http://localhost:8025).
# In prod, switch to 'resend' and set RESEND_API_KEY.
EMAIL_PROVIDER=mailpit
EMAIL_FROM=Vital30 <no-reply@vital30.local>
MAILPIT_HOST=localhost
MAILPIT_PORT=1025
RESEND_API_KEY=

# Database
POSTGRES_USER=vital30
POSTGRES_PASSWORD=vital30_password
POSTGRES_DB=vital30_db
DATABASE_URL=postgresql://vital30:vital30_password@localhost:5432/vital30_db?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Admin
VITE_API_BASE_URL=http://localhost:3000

# Flutter
API_BASE_URL=http://localhost:3000
