# ==============================================================================
# Vital30 Production Environment Configuration
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.prod.example .env
# 2. Update all placeholders (<...>) with strong production-grade secrets.
# 3. Ensure this file is never committed to source control (it is ignored by .gitignore).
# ==============================================================================

# General
NODE_ENV=production

# API Configurations
API_PORT=3000
# Generate a strong 256-bit secret using: openssl rand -base64 32
JWT_SECRET=<STRONG_SECURE_JWT_SECRET_RANDOM_HEX>
JWT_EXPIRES_IN=7d
CORS_ORIGIN=https://admin.vital30.com

# PostgreSQL Production Database (Exposed exclusively within Docker bridge network)
POSTGRES_USER=vital30_prod_admin
# Generate a strong 24+ character password
POSTGRES_PASSWORD=<STRONG_RANDOM_DATABASE_PASSWORD_KEY>
POSTGRES_DB=vital30_prod_db
# Note: "postgres" points to the internal Docker service name, NOT localhost
DATABASE_URL=postgresql://vital30_prod_admin:<STRONG_RANDOM_DATABASE_PASSWORD_KEY>@postgres:5432/vital30_prod_db?schema=public

# Redis Configuration (Exposed exclusively within Docker bridge network)
REDIS_HOST=redis
REDIS_PORT=6379

# React Admin App Build Args (Injected during Docker image compilation)
# Note: Must use HTTPS for production security
VITE_API_BASE_URL=https://api.vital30.com

# Flutter Mobile App API Endpoint
API_BASE_URL=https://api.vital30.com
