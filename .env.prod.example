# =============================================================================
# Vital30 production environment template
# =============================================================================
# Copy to .env and replace every <REPLACE_ME_*> placeholder with a real value.
# The deploy script (scripts/deploy-prod.sh) refuses to run while any
# placeholder remains.
#
# Generate secrets with:
#   openssl rand -base64 32      # for BETTER_AUTH_SECRET
#   openssl rand -base64 24      # for POSTGRES_PASSWORD
#
# NEVER commit a populated .env to source control. .env is gitignored.
# =============================================================================

NODE_ENV=production

# --- API ------------------------------------------------------------------
API_PORT=3000

# Better Auth signs sessions with this. Must be >= 32 chars in any non-local
# environment. NEVER reuse the local dev value.
BETTER_AUTH_SECRET=<REPLACE_ME_BETTER_AUTH_SECRET>

# Public URL where the API serves Better Auth routes (used in email links
# for password reset + email verification). Must match the deployed origin.
BETTER_AUTH_URL=https://api.vital30.com

# Comma-separated list of allowed CORS origins. Add the public website +
# admin URLs (HTTPS, no trailing slash).
CORS_ORIGIN=https://vital30.com,https://www.vital30.com,https://admin.vital30.com

# --- Email ----------------------------------------------------------------
# Production must use a real provider. Recommended: Resend (resend.com).
# Get a key from https://resend.com/api-keys.
EMAIL_PROVIDER=resend
EMAIL_FROM=Vital30 <no-reply@vital30.com>
RESEND_API_KEY=<REPLACE_ME_RESEND_API_KEY>

# Where public contact-form submissions are delivered. Falls back to
# EMAIL_FROM if unset.
CONTACT_INBOX=hello@vital30.com

# --- Database -------------------------------------------------------------
POSTGRES_USER=vital30_prod
POSTGRES_PASSWORD=<REPLACE_ME_POSTGRES_PASSWORD>
POSTGRES_DB=vital30_prod_db
DATABASE_URL=postgresql://vital30_prod:<REPLACE_ME_POSTGRES_PASSWORD>@postgres:5432/vital30_prod_db?schema=public

# --- Redis (currently unused by the API; reserved for queues + caching) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Admin (apps/admin) ---------------------------------------------------
# Baked into the SPA at build time.
VITE_API_BASE_URL=https://api.vital30.com

# --- Public website (apps/web) --------------------------------------------
# Baked into the Next.js standalone build at build time.
NEXT_PUBLIC_API_BASE_URL=https://api.vital30.com
NEXT_PUBLIC_SITE_URL=https://vital30.com
