generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppInfo {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ChallengeDifficulty {
  BEGINNER
  EASY
  MEDIUM
  HARD
}

enum UserChallengeStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum CheckinStatus {
  COMPLETED
  MISSED
  SKIPPED
}

enum ShareType {
  CHALLENGE_INVITE
  DAILY_PROGRESS
  COMPLETION
}

// Visibility for user-created challenges. Seeded challenges (no
// createdById) ignore this field — they're always public.
enum ChallengeVisibility {
  PRIVATE   // only people with the inviteToken URL OR an explicit invite can see/join
  PUBLIC    // also shows up in /challenges browse alongside seeded challenges
}

enum ChallengeInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum NotificationType {
  STREAK_MILESTONE
  CHALLENGE_COMPLETE
  REMINDER
  REFERRAL_JOIN
  SYSTEM
  ACHIEVEMENT
}

enum AchievementKind {
  FIRST_CHECKIN
  SEVEN_DAY_STREAK
  TWENTY_ONE_DAY_STREAK
  CHALLENGE_COMPLETED
  THREE_CHALLENGES_COMPLETED
}

// Owned by Better Auth — the canonical fields below (name, email,
// emailVerified, image, createdAt, updatedAt) are required by its Prisma
// adapter. `role` and the domain relations (userChallenges, shareEvents)
// are Vital30 extensions.
model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Public-facing Instagram-style handle. Lowercase, 3-30 chars,
  // alphanumeric + `.` `_`. Unique across users. Optional in the DB
  // (so existing rows + the migration don't trip) but enforced as
  // required in the signup form. Profile editing for username is
  // intentionally NOT exposed in this iteration — handle squatting
  // and link rot are real problems we'll address with a cooldown
  // policy later. New rows get one at signup or are auto-backfilled
  // by the seed script.
  username      String?  @unique
  // E.164 phone (e.g. +14155552671). Unique across users. Optional —
  // user can sign up without a phone and add it later from /profile.
  // Profile/contact field only — there is intentionally NO phone-OTP
  // or SMS login (descoped; auth is email/username + password).
  phone         String?  @unique

  // -- Personal details + onboarding (all optional; collected via the
  //    skippable /welcome flow and editable from /profile) ------------
  gender          Gender?
  // Data minimisation: we store only the YEAR of birth, never the full
  // date. Year alone is enough to (a) gate under-13 signups (COPPA /
  // GDPR-K) and (b) show an approximate age, while dropping the precise
  // day+month that makes a full DOB an identity-grade data point.
  birthYear       Int?
  // Stored canonical in METRIC; the client converts for display based
  // on unitPreference. Height in whole centimetres, weight in kg (one
  // decimal of precision is plenty — Float).
  heightCm        Int?
  weightKg        Float?
  unitPreference  UnitPreference @default(METRIC)
  // Goal signals that power challenge recommendations.
  primaryGoal     PrimaryGoal?
  // Category IDs the user said they're interested in (multi-select on
  // the welcome flow). Drives the personalised "Recommended for you"
  // lane. String[] of ChallengeCategory.id values.
  interestCategoryIds String[] @default([])
  // Minutes/day the user can commit — soft-filters recommended
  // challenges by difficulty.
  dailyMinutes    Int?
  // Set when the user finishes (or explicitly skips all of) the
  // welcome flow, so we don't keep redirecting them there.
  onboardingCompletedAt DateTime?

  role UserRole @default(USER)

  // Admin moderation flag — false = account suspended by an admin. The
  // sign-in hook (auth.ts) rejects suspended accounts, and suspending also
  // revokes active sessions. Toggled from the admin dashboard.
  isActive Boolean @default(true)

  // Vital30 — referral system. `referralCode` is auto-assigned on signup
  // (8-char base32-ish slug); `referredById` is set if this user signed up
  // via someone's invite code.
  referralCode   String?  @unique
  referredById   String?  @db.Uuid
  referredBy     User?    @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals      User[]   @relation("UserReferrals")

  sessions       Session[]
  accounts       Account[]
  auditLogs      AuditLog[]
  userChallenges UserChallenge[]
  shareEvents    ShareEvent[]
  notifications  Notification[]
  favorites      Favorite[]
  achievements   Achievement[]

  // Custom challenges feature
  createdChallenges Challenge[]       @relation("CreatedChallenges")
  invitesSent       ChallengeInvite[] @relation("ChallengeInvitesSent")
  invitesReceived   ChallengeInvite[] @relation("ChallengeInvitesReceived")

  // Per-challenge community chat
  chatMessages  ChallengeChatMessage[]
  chatReactions ChatReaction[]

  // Challenge friends — symmetric semantically but stored as one row
  // per pair; the relation names track who originated the request.
  sentFriendRequests     ChallengeFriendship[] @relation("FriendshipRequester")
  receivedFriendRequests ChallengeFriendship[] @relation("FriendshipRecipient")
}

// Better Auth — one row per active session. We use bearer tokens (mobile)
// so the `token` field is what the client sends in Authorization.
model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Better Auth — credentials live here (provider='credential', password=hash).
// Future OAuth providers (Apple, Google) write additional rows per user.
model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

// Better Auth — short-lived tokens (password reset, email verify).
model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// Append-only audit trail for security-relevant events. One row per
// event; `action` is a dotted namespace (e.g. "auth.signup",
// "auth.login.failed", "user.role_changed"). `userId` is nullable so we
// can record pre-authentication events (signup attempts, password reset
// requests for unknown emails) and so deleting a user via the cascade
// chain doesn't erase their audit history — onDelete: SetNull keeps the
// row but breaks the foreign key cleanly.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ChallengeCategory {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  slug        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  challenges  Challenge[]
}

model Challenge {
  id               String              @id @default(uuid()) @db.Uuid
  title            String
  slug             String              @unique
  shortDescription String
  description      String
  durationDays     Int                 @default(30)
  difficulty       ChallengeDifficulty
  dailyTask        String
  benefits         Json
  safetyNote       String?
  isPopular        Boolean             @default(false)
  isRecommended    Boolean             @default(false)
  isActive         Boolean             @default(true)
  categoryId       String              @db.Uuid
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  // Custom-challenge fields. NULL on the seeded catalog. createdById
  // SetNull so a creator deleting their account doesn't cascade-delete
  // every challenge they made and orphan everyone's check-ins.
  createdById      String?             @db.Uuid
  createdBy        User?               @relation("CreatedChallenges", fields: [createdById], references: [id], onDelete: SetNull)
  visibility       ChallengeVisibility @default(PUBLIC)
  inviteToken      String?             @unique

  category         ChallengeCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userChallenges   UserChallenge[]
  favorites        Favorite[]
  invites          ChallengeInvite[]
  chatMessages     ChallengeChatMessage[]

  @@index([categoryId])
  @@index([createdById])
  @@index([visibility])
}

model UserChallenge {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @db.Uuid
  challengeId String              @db.Uuid
  status      UserChallengeStatus @default(ACTIVE)
  startDate   DateTime            @default(now())
  endDate     DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  checkins    DailyCheckin[]

  @@unique([userId, challengeId])
  @@index([userId])
}

model DailyCheckin {
  id              String        @id @default(uuid()) @db.Uuid
  userChallengeId String        @db.Uuid
  checkinDate     DateTime      @db.Date
  status          CheckinStatus
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  userChallenge   UserChallenge @relation(fields: [userChallengeId], references: [id], onDelete: Cascade)

  @@unique([userChallengeId, checkinDate])
  @@index([userChallengeId])
}

model ShareEvent {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  type      ShareType
  platform  String?
  payload   Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// In-app notifications inbox. Server emits one row per event for the user
// (e.g. streak milestone hit, challenge completed, referral signup). Mobile
// reads `readAt`/`unread` to show the inbox + badge counts.
model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// User's saved challenges. One row per (user, challenge). Browse + Join
// flow surfaces "Favorites" alongside "My Challenges" in the mobile app.
model Favorite {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  challengeId String   @db.Uuid
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
}

// Public contact form submissions. Anyone can POST to /public/contact;
// these get persisted here for admin triage in addition to being emailed
// to CONTACT_INBOX. `resolvedAt` flips to a timestamp once a human has
// dealt with it (e.g. via the admin dashboard once that ships).
model ContactSubmission {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  email      String
  message    String
  ipAddress  String?
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([resolvedAt])
}

// Invite to a custom challenge. Created by the challenge's owner when
// they explicitly invite someone by email. If the invited email already
// belongs to a Vital30 user, invitedUserId resolves immediately so the
// invite shows up in their /invites inbox. Otherwise the invite still
// gets stored, and we send the invitee a real email with the join link;
// when they sign up later, a backfill job (or signup hook) can resolve
// `invitedUserId`.
//
// The shareable-link path does NOT create a ChallengeInvite — the link
// just contains the Challenge's inviteToken. Open-token joins are
// tracked in UserChallenge like any other join.
model ChallengeInvite {
  id              String                @id @default(uuid()) @db.Uuid
  challengeId     String                @db.Uuid
  challenge       Challenge             @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  invitedById     String                @db.Uuid
  invitedBy       User                  @relation("ChallengeInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedEmail    String
  invitedUserId   String?               @db.Uuid
  invitedUser     User?                 @relation("ChallengeInvitesReceived", fields: [invitedUserId], references: [id], onDelete: SetNull)
  status          ChallengeInviteStatus @default(PENDING)
  createdAt       DateTime              @default(now())
  respondedAt     DateTime?

  @@unique([challengeId, invitedEmail])
  @@index([invitedUserId])
  @@index([invitedEmail])
}

// Earned achievement (badge). Unique per (user, kind) so each badge can be
// awarded only once. Kind-specific metadata (e.g. which challenge unlocked
// it) lives in `data`.
model Achievement {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      AchievementKind
  data      Json?
  earnedAt  DateTime        @default(now())

  @@unique([userId, kind])
  @@index([userId])
}



// =============================================================================
// Per-challenge community chat
// =============================================================================
// Each Challenge has a single shared chat visible to everyone who joined it
// (any UserChallenge status). Two kinds of messages live in the same table:
//
//   PRESET      — user-posted, but constrained to a fixed catalog of preset
//                 codes (no free-text). Avoids abuse + keeps the channel
//                 focused on shared check-in moments. presetCode is the
//                 catalog key; the client resolves it to display text.
//   CELEBRATION — auto-generated card, ONE per day per challenge, lazily
//                 materialised on the first GET of the day (no cron). body
//                 is the rendered celebration copy. scheduledDate is the
//                 UTC date the card represents.
//
// A unique constraint on (challengeId, kind, scheduledDate) makes the
// once-a-day celebration race-safe — a parallel first-view from two clients
// both upsert and only one row lands.
//
// The daily check-in poll is NOT stored here — it is derived live from
// DailyCheckin rows on read so it always reflects the current counts. No
// row to keep in sync, no eventual-consistency surprise.

enum ChatMessageKind {
  PRESET
  CELEBRATION
}

model ChallengeChatMessage {
  id            String          @id @default(uuid()) @db.Uuid
  challengeId   String          @db.Uuid
  // null for CELEBRATION; SetNull so a user deleting their account does
  // not cascade-delete the community history their messages live in.
  userId        String?         @db.Uuid
  kind          ChatMessageKind
  presetCode    String?
  body          String?
  scheduledDate DateTime?       @db.Date
  createdAt     DateTime        @default(now())

  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  reactions     ChatReaction[]

  @@unique([challengeId, kind, scheduledDate], name: "uniq_celebration_per_day")
  @@index([challengeId, createdAt(sort: Desc)])
}

// One row per (message, user, emoji). Toggling re-uses the row (delete +
// re-create) so totals match the user-facing toggle UX. emoji is stored as
// a short ASCII code ("fire", "love", …) — the client maps to the actual
// character so we can swap visuals without a DB migration.
model ChatReaction {
  id         String   @id @default(uuid()) @db.Uuid
  messageId  String   @db.Uuid
  userId     String   @db.Uuid
  emoji      String
  createdAt  DateTime @default(now())

  message    ChallengeChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// =============================================================================
// Challenge friends
// =============================================================================
// User-to-user friendship graph used by the chat Members sheet:
//   - Add Friend → creates a PENDING row, requester is the viewer
//   - Recipient sees it on /friends and Accepts (→ ACCEPTED) or Declines
//     (→ DECLINED). Notifications fire both ways.
//   - Once ACCEPTED, both parties can invite each other to their custom
//     challenges via the existing POST /custom-challenges/:id/invites/by-user
//     flow.
//
// Friendship is symmetric in meaning but stored asymmetrically (one row
// per pair) — the row remembers who initiated, which is useful for
// "pending sent vs pending received" UX cues. Lookups for "is X my
// friend?" query both directions via OR.
//
// @@unique([requesterId, recipientId]) prevents duplicate requests in
// the same direction. The cross-direction case (A requests B while B
// already requested A) is handled in the service: an accept-on-collision
// promotes the existing PENDING to ACCEPTED instead of creating a
// second row.

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum UnitPreference {
  METRIC
  IMPERIAL
}

// Primary wellness goal — the headline answer from the onboarding
// questionnaire. Maps (softly) to challenge categories for the
// recommendation scorer (see challenges recommendation service).
enum PrimaryGoal {
  LOSE_WEIGHT
  BUILD_FITNESS
  BETTER_SLEEP
  MENTAL_WELLNESS
  EAT_BETTER
  BREAK_HABIT
  GENERAL_WELLNESS
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  // Viewer blocked the other party. The row's `requesterId` is always
  // the blocker; the recipient is the one being blocked. The friends
  // service refuses to create / promote any row between two users when
  // a BLOCKED row exists in either direction.
  BLOCKED
}

model ChallengeFriendship {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @db.Uuid
  recipientId String           @db.Uuid
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  respondedAt DateTime?

  requester User @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient User @relation("FriendshipRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([recipientId, status])
  @@index([requesterId, status])
}
