generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppInfo {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ChallengeDifficulty {
  BEGINNER
  EASY
  MEDIUM
  HARD
}

enum UserChallengeStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum CheckinStatus {
  COMPLETED
  MISSED
  SKIPPED
}

enum ShareType {
  CHALLENGE_INVITE
  DAILY_PROGRESS
  COMPLETION
}

// Visibility for user-created challenges. Seeded challenges (no
// createdById) ignore this field — they're always public.
enum ChallengeVisibility {
  PRIVATE   // only people with the inviteToken URL OR an explicit invite can see/join
  PUBLIC    // also shows up in /challenges browse alongside seeded challenges
}

enum ChallengeInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum NotificationType {
  STREAK_MILESTONE
  CHALLENGE_COMPLETE
  REMINDER
  REFERRAL_JOIN
  SYSTEM
  ACHIEVEMENT
}

enum AchievementKind {
  FIRST_CHECKIN
  SEVEN_DAY_STREAK
  TWENTY_ONE_DAY_STREAK
  CHALLENGE_COMPLETED
  THREE_CHALLENGES_COMPLETED
}

// Owned by Better Auth — the canonical fields below (name, email,
// emailVerified, image, createdAt, updatedAt) are required by its Prisma
// adapter. `role` and the domain relations (userChallenges, shareEvents)
// are Vital30 extensions.
model User {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  role UserRole @default(USER)

  // Vital30 — referral system. `referralCode` is auto-assigned on signup
  // (8-char base32-ish slug); `referredById` is set if this user signed up
  // via someone's invite code.
  referralCode   String?  @unique
  referredById   String?  @db.Uuid
  referredBy     User?    @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals      User[]   @relation("UserReferrals")

  sessions       Session[]
  accounts       Account[]
  auditLogs      AuditLog[]
  userChallenges UserChallenge[]
  shareEvents    ShareEvent[]
  notifications  Notification[]
  favorites      Favorite[]
  achievements   Achievement[]

  // Custom challenges feature
  createdChallenges Challenge[]       @relation("CreatedChallenges")
  invitesSent       ChallengeInvite[] @relation("ChallengeInvitesSent")
  invitesReceived   ChallengeInvite[] @relation("ChallengeInvitesReceived")
}

// Better Auth — one row per active session. We use bearer tokens (mobile)
// so the `token` field is what the client sends in Authorization.
model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// Better Auth — credentials live here (provider='credential', password=hash).
// Future OAuth providers (Apple, Google) write additional rows per user.
model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

// Better Auth — short-lived tokens (password reset, email verify).
model Verification {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// Append-only audit trail for security-relevant events. One row per
// event; `action` is a dotted namespace (e.g. "auth.signup",
// "auth.login.failed", "user.role_changed"). `userId` is nullable so we
// can record pre-authentication events (signup attempts, password reset
// requests for unknown emails) and so deleting a user via the cascade
// chain doesn't erase their audit history — onDelete: SetNull keeps the
// row but breaks the foreign key cleanly.
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @db.Uuid
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model ChallengeCategory {
  id          String      @id @default(uuid()) @db.Uuid
  name        String
  slug        String      @unique
  description String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  challenges  Challenge[]
}

model Challenge {
  id               String              @id @default(uuid()) @db.Uuid
  title            String
  slug             String              @unique
  shortDescription String
  description      String
  durationDays     Int                 @default(30)
  difficulty       ChallengeDifficulty
  dailyTask        String
  benefits         Json
  safetyNote       String?
  isPopular        Boolean             @default(false)
  isRecommended    Boolean             @default(false)
  isActive         Boolean             @default(true)
  categoryId       String              @db.Uuid
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  // Custom-challenge fields. NULL on the seeded catalog. createdById
  // SetNull so a creator deleting their account doesn't cascade-delete
  // every challenge they made and orphan everyone's check-ins.
  createdById      String?             @db.Uuid
  createdBy        User?               @relation("CreatedChallenges", fields: [createdById], references: [id], onDelete: SetNull)
  visibility       ChallengeVisibility @default(PUBLIC)
  inviteToken      String?             @unique

  category         ChallengeCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userChallenges   UserChallenge[]
  favorites        Favorite[]
  invites          ChallengeInvite[]

  @@index([categoryId])
  @@index([createdById])
  @@index([visibility])
}

model UserChallenge {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @db.Uuid
  challengeId String              @db.Uuid
  status      UserChallengeStatus @default(ACTIVE)
  startDate   DateTime            @default(now())
  endDate     DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge           @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  checkins    DailyCheckin[]

  @@unique([userId, challengeId])
  @@index([userId])
}

model DailyCheckin {
  id              String        @id @default(uuid()) @db.Uuid
  userChallengeId String        @db.Uuid
  checkinDate     DateTime      @db.Date
  status          CheckinStatus
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  userChallenge   UserChallenge @relation(fields: [userChallengeId], references: [id], onDelete: Cascade)

  @@unique([userChallengeId, checkinDate])
  @@index([userChallengeId])
}

model ShareEvent {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  type      ShareType
  platform  String?
  payload   Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// In-app notifications inbox. Server emits one row per event for the user
// (e.g. streak milestone hit, challenge completed, referral signup). Mobile
// reads `readAt`/`unread` to show the inbox + badge counts.
model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

// User's saved challenges. One row per (user, challenge). Browse + Join
// flow surfaces "Favorites" alongside "My Challenges" in the mobile app.
model Favorite {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  challengeId String   @db.Uuid
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@index([userId])
}

// Public contact form submissions. Anyone can POST to /public/contact;
// these get persisted here for admin triage in addition to being emailed
// to CONTACT_INBOX. `resolvedAt` flips to a timestamp once a human has
// dealt with it (e.g. via the admin dashboard once that ships).
model ContactSubmission {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  email      String
  message    String
  ipAddress  String?
  resolvedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([resolvedAt])
}

// Invite to a custom challenge. Created by the challenge's owner when
// they explicitly invite someone by email. If the invited email already
// belongs to a Vital30 user, invitedUserId resolves immediately so the
// invite shows up in their /invites inbox. Otherwise the invite still
// gets stored, and we send the invitee a real email with the join link;
// when they sign up later, a backfill job (or signup hook) can resolve
// `invitedUserId`.
//
// The shareable-link path does NOT create a ChallengeInvite — the link
// just contains the Challenge's inviteToken. Open-token joins are
// tracked in UserChallenge like any other join.
model ChallengeInvite {
  id              String                @id @default(uuid()) @db.Uuid
  challengeId     String                @db.Uuid
  challenge       Challenge             @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  invitedById     String                @db.Uuid
  invitedBy       User                  @relation("ChallengeInvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedEmail    String
  invitedUserId   String?               @db.Uuid
  invitedUser     User?                 @relation("ChallengeInvitesReceived", fields: [invitedUserId], references: [id], onDelete: SetNull)
  status          ChallengeInviteStatus @default(PENDING)
  createdAt       DateTime              @default(now())
  respondedAt     DateTime?

  @@unique([challengeId, invitedEmail])
  @@index([invitedUserId])
  @@index([invitedEmail])
}

// Earned achievement (badge). Unique per (user, kind) so each badge can be
// awarded only once. Kind-specific metadata (e.g. which challenge unlocked
// it) lives in `data`.
model Achievement {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @db.Uuid
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      AchievementKind
  data      Json?
  earnedAt  DateTime        @default(now())

  @@unique([userId, kind])
  @@index([userId])
}

