{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "setupFiles": ["./setup-env.ts"],
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@thallesp/nestjs-better-auth$": "<rootDir>/mocks/nestjs-better-auth.mock.ts",
    "^better-auth$": "<rootDir>/mocks/better-auth.mock.ts",
    "^better-auth/adapters/prisma$": "<rootDir>/mocks/better-auth-adapters-prisma.mock.ts",
    "^better-auth/plugins$": "<rootDir>/mocks/better-auth-plugins.mock.ts"
  }
}

