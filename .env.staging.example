# =============================================================================
# Vital30 STAGING environment template
# =============================================================================
# Copy to .env.staging and replace every <REPLACE_ME_*> placeholder.
# scripts/deploy-staging.sh refuses to run while any placeholder remains.
#
# .env.staging is gitignored — NEVER commit a populated copy. Only this
# .env.staging.example template is tracked.
#
# Generate secrets with:
#   openssl rand -base64 32      # for BETTER_AUTH_SECRET
#   openssl rand -base64 24      # for POSTGRES_PASSWORD
#
# Use DIFFERENT secrets from production — staging is for testing and should
# never be able to read/write prod data or sign prod-valid sessions.
# =============================================================================

NODE_ENV=production

# --- API ------------------------------------------------------------------
API_PORT=3000

# Better Auth session signing secret (>= 32 chars). Generate a fresh one;
# do NOT reuse the production value.
BETTER_AUTH_SECRET=<REPLACE_ME_STAGING_BETTER_AUTH_SECRET>

# Public URL where the staging API serves Better Auth routes.
BETTER_AUTH_URL=https://api.staging.challenge.charangudla.com

# Allowed CORS origins (HTTPS, no trailing slash) — staging site + admin.
# Better Auth also uses these as trustedOrigins for sign-in / sign-up.
CORS_ORIGIN=https://staging.challenge.charangudla.com,https://admin.staging.challenge.charangudla.com

# Cookie scope for cross-subdomain sessions on the staging zone. Scoped to
# .staging.challenge.charangudla.com so staging cookies never collide with
# the prod cookie on .challenge.charangudla.com.
COOKIE_DOMAIN=.staging.challenge.charangudla.com

# --- Email ----------------------------------------------------------------
# Resend verifies senders per-domain. EMAIL_FROM reuses the already-verified
# prod domain so staging emails actually send. If you'd rather isolate staging
# mail, verify a separate domain/subdomain in Resend and use it here.
EMAIL_PROVIDER=resend
EMAIL_FROM=Vital30 Staging <no-reply@challenge.charangudla.com>
RESEND_API_KEY=<REPLACE_ME_STAGING_RESEND_API_KEY>

# Where staging contact-form submissions are delivered.
CONTACT_INBOX=hello@challenge.charangudla.com

# --- Database -------------------------------------------------------------
# Separate user + DB name from prod. This Postgres runs in its OWN staging
# container on its OWN volume (postgres_staging_data) — fully isolated.
POSTGRES_USER=vital30_staging
POSTGRES_PASSWORD=<REPLACE_ME_STAGING_POSTGRES_PASSWORD>
POSTGRES_DB=vital30_staging_db
DATABASE_URL=postgresql://vital30_staging:<REPLACE_ME_STAGING_POSTGRES_PASSWORD>@postgres:5432/vital30_staging_db?schema=public

# --- Redis ----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# --- Admin (apps/admin) ---------------------------------------------------
# Baked into the SPA at build time.
VITE_API_BASE_URL=https://api.staging.challenge.charangudla.com

# --- Public website (apps/web) --------------------------------------------
# Baked into the Next.js standalone build at build time.
NEXT_PUBLIC_API_BASE_URL=https://api.staging.challenge.charangudla.com
NEXT_PUBLIC_SITE_URL=https://staging.challenge.charangudla.com
